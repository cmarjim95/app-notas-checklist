# Ejemplo de variables de entorno
# Copia este archivo a `.env` y completa los valores.

# Frontend (Vite): prefijo VITE_
VITE_API_URL=https://api.example.com
VITE_API_KEY=your_frontend_api_key_here

# Firebase (si aplica)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# Backend / Servicios (no poner secretos públicos en frontend)
API_URL=https://api.example.com
DATABASE_URL=postgres://user:password@host:5432/dbname
JWT_SECRET=your_jwt_secret_here

# Herramientas de monitoreo
SENTRY_DSN=

# Pasos: crea un archivo `.env` basado en este y NO subas `.env` al repositorio.
